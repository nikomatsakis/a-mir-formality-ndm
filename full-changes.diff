+    /// Instantiate the given binder universally in this environment,
+    pub fn instantiate_universally<T>(&self, binder: &Binder<T>) -> (T, TypeckEnv)
+    where
+        T: Fold + Clone,
+    {
+        let mut env = self.env.clone();
+        let value = env.instantiate_universally(binder);
+        (
+            value,
+            TypeckEnv {
+                env,
+                ..self.clone()
+            },
+        )
+    }
