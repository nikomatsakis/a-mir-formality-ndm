+                    c_outlives.insert(PendingOutlives {
+                        location: location.clone(),
+                        a,
+                        b,
+                    });
+                }
+
+                _ => {
+                    // give up
+                    return None;
+                }
+            }
+        }
+
+        Some(c_outlives)
+    }
