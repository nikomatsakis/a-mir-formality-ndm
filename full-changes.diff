+        env: TypeckEnv,
+        assumptions: Wcs,
+        loan: Loan,
+        lifetime: Lt,
+    ) => () {
+        debug(loan, lifetime, assumptions, env)
+
+        (
+            (let outlived_by_loan = transitively_outlived_by(&env, &loan.lt))
+            (if !outlived_by_loan.contains(&lifetime.upcast()))
+            --- ("loan_cannot_outlive")
+            (loan_cannot_outlive(env, _assumptions, loan, lifetime) => ())
+        )
+    }
+}
